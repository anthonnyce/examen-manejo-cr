# Copia este archivo como ".env" y llena tus valores reales

# URL de conexión a PostgreSQL (Neon, Supabase, Railway, o local)
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_basedatos

# Pon "false" solo si tu Postgres es local sin SSL
DATABASE_SSL=true

# Secreto para firmar los tokens de sesión (usa una cadena larga y aleatoria)
JWT_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio

PORT=3000

# URL de tu frontend (se usa para armar el enlace de recuperación de contraseña)
FRONTEND_URL=http://localhost:5500

# Opcional: para enviar el correo real de recuperación de contraseña.
# Si lo dejás vacío, el enlace solo se imprime en la consola del backend (modo desarrollo).
RESEND_API_KEY=
RESEND_FROM=RutaCR <no-reply@tudominio.com>
